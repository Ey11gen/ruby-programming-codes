# Explicit return (guard clause)
def safe_divide(a, b)
  if b == 0
    return "Cannot divide by zero."
  end
  a.to_f / b
end

puts safe_divide(10, 2)
puts safe_divide(7, 0)
puts safe_divide(9, 4)

# Chapter 7 – Required, optional, keyword, and splat parameters

# Required parameters
def introduce(name, age, city)
  puts "My name is #{name}."
  puts "I am #{age} years old."
  puts "I live in #{city}."
end
introduce("Sofia", 31, "Athens")

# Optional parameters with defaults
def greet(name, greeting = "Hello", punctuation = "!")
  puts "#{greeting}, #{name}#{punctuation}"
end
greet("Alice")
greet("Bob", "Good morning")
greet("Carlos", "Welcome", ".")

# Keyword parameters
def create_user(name:, age:, email:, role: "member")
  puts "Creating user: #{name}"
  puts "  Age:   #{age}"
  puts "  Email: #{email}"
  puts "  Role:  #{role}"
end
create_user(name: "Aisha", age: 25, email: "aisha@example.com")
create_user(email: "raj@example.com", name: "Raj", age: 33, role: "admin")

# Splat parameters
def sum_all(*numbers)
  total = 0
  numbers.each { |n| total += n }
  total
end
puts sum_all(1, 2, 3)
puts sum_all(10, 20, 30, 40, 50)
puts sum_all

def log(level, *messages)
  messages.each do |msg|
    puts "[#{level.upcase}] #{msg}"
  end
end
log("info", "Server started.", "Listening on port 3000.")
log("error", "Database connection failed.")

# Chapter 7 – Predicate methods, bang methods, and aliases

def valid_email?(email)
  email.include?("@") && email.include?(".")
end

def adult?(age)
  age >= 18
end

def empty_string?(str)
  str.strip.length == 0
end

puts valid_email?("user@example.com")
puts valid_email?("notanemail")
puts adult?(20)
puts adult?(15)
puts empty_string?("   ")
puts empty_string?("hello")

# Bang method
def normalize!(text)
  text.strip!
  text.downcase!
  text.gsub!(/\s+/, "_")
  text
end

label = "  Hello World  "
puts label.inspect
normalize!(label)
puts label.inspect

