# Chapter 7 – Organizing code: receipt generator

def format_currency(amount)
  "$#{format('%.2f', amount)}"
end

def calculate_subtotal(items)
  items.sum { |item| item[:price] * item[:quantity] }
end

def calculate_tax(subtotal, rate = 0.08)
  subtotal * rate
end

def calculate_total(subtotal, tax)
  subtotal + tax
end

def print_receipt(customer, items)
  puts "=" * 40
  puts "Receipt for #{customer}"
  puts "=" * 40
  items.each do |item|
    line_total = item[:price] * item[:quantity]
    puts "#{item[:name].ljust(20)} #{item[:quantity]} x #{format_currency(item[:price])} = #{format_currency(line_total)}"
  end
  puts "-" * 40
  subtotal = calculate_subtotal(items)
  tax      = calculate_tax(subtotal)
  total    = calculate_total(subtotal, tax)
  puts "Subtotal: #{format_currency(subtotal).rjust(28)}"
  puts "Tax (8%): #{format_currency(tax).rjust(28)}"
  puts "Total:    #{format_currency(total).rjust(28)}"
  puts "=" * 40
end

order_items = [
  { name: "Ruby Programming Book", price: 39.99, quantity: 1 },
  { name: "USB-C Cable",           price:  9.99, quantity: 2 },
  { name: "Mechanical Keyboard",   price: 89.99, quantity: 1 },
]

print_receipt("Alice Martin", order_items)
