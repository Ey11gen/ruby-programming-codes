<%# Chapter 18 – reusable form partial %>

<%= form_with(model: task) do |form| %>
  <% if task.errors.any? %>
    <div class="errors">
      <h3><%= task.errors.count %> error(s) prevented saving:</h3>
      <ul>
        <% task.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title %>
    <%= form.text_field :title, placeholder: "Enter task title" %>
  </div>

  <div>
    <%= form.label :description %>
    <%= form.text_area :description, rows: 4 %>
  </div>

  <div>
    <%= form.label :priority %>
    <%= form.select :priority, Task::PRIORITY_LABELS.map { |v, l| [l, v] }, {}, class: "select" %>
  </div>

  <div>
    <%= form.label :completed %>
    <%= form.check_box :completed %>
  </div>

  <%= form.submit %>
<% end %>

