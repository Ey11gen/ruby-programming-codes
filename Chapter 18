<%# Chapter 18 – index view %>

<h1>Task Manager</h1>

<% if notice %>
  <div class="notice"><%= notice %></div>
<% end %>

<%= link_to "New Task", new_task_path, class: "btn btn-primary" %>

<% if @tasks.any? %>
  <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Priority</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @tasks.each do |task| %>
        <tr class="<%= task.completed? ? 'completed' : 'pending' %>">
          <td><%= task.title %></td>
          <td><%= task.priority_label %></td>
          <td><%= task.completed? ? "Done" : "Pending" %></td>
          <td>
            <%= link_to "View",   task_path(task),      class: "btn" %>
            <%= link_to "Edit",   edit_task_path(task), class: "btn" %>
            <%= link_to "Delete", task_path(task),
                        data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                        class: "btn btn-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No tasks yet. Create your first task!</p>
<% end %>

