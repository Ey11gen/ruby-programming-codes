# Nested module namespace example (as used across files)
module Helpers
  module Validator
    def valid_username?(name)
      name.is_a?(String) && name.length >= 3 && name.length <= 20
    end

    def valid_email?(email)
      email.is_a?(String) && email.match?(/\A[\w.]+@[\w.]+\.\w+\z/)
    end
  end
end

module Models
  class User
    include Helpers::Validator

    attr_reader :username, :email

    def initialize(username, email)
      @username = username
      @email    = email
    end

    def valid?
      valid_username?(@username) && valid_email?(@email)
    end
  end
end

u1 = Models::User.new("alice", "alice@example.com")
u2 = Models::User.new("ab", "notanemail")
puts u1.valid?
puts u2.valid?
