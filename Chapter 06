# Iterating
inventory = {
  apples:   150,
  bananas:  80,
  cherries: 320,
  dates:    45
}

inventory.each do |item, quantity|
  puts "#{item}: #{quantity} units in stock"
end

puts inventory.keys.inspect
puts inventory.values.inspect
puts inventory.to_a.inspect

expensive = inventory.select { |item, qty| qty > 100 }
puts expensive.inspect

doubled = inventory.transform_values { |qty| qty * 2 }
puts doubled.inspect

# Chapter 6 – Nested arrays and hashes

students = [
  { name: "Alice",  grades: [88, 92, 79, 95], city: "London" },
  { name: "Bob",    grades: [75, 81, 90, 70], city: "Paris"  },
  { name: "Carlos", grades: [95, 98, 92, 97], city: "Madrid" },
]

puts students[0][:name]
puts students[1][:city]
puts students[2][:grades][1]
puts students[0][:grades].sum

students.each do |student|
  average = student[:grades].sum.to_f / student[:grades].length
  puts "#{student[:name]} (#{student[:city]}): average #{average.round(1)}"
end

company = {
  name: "RubyTech",
  departments: {
    engineering: { head: "Sara",  staff: 12, budget: 500_000 },
    marketing:   { head: "James", staff: 5,  budget: 200_000 },
    support:     { head: "Leila", staff: 8,  budget: 150_000 },
  }
}

puts company[:name]
puts company[:departments][:engineering][:head]
puts company[:departments][:marketing][:budget]

company[:departments].each do |dept_name, dept_info|
  puts "#{dept_name}: led by #{dept_info[:head]}, #{dept_info[:staff]} staff"
end

total_staff = company[:departments].sum { |_, info| info[:staff] }
puts "Total staff: #{total_staff}"

