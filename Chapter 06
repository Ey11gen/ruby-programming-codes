# Chapter 6 – Essential array methods

stack = []
stack.push("first")
stack.push("second", "third")
puts stack.inspect

removed = stack.pop
puts "Removed: #{removed}"
puts stack.inspect

stack.unshift("zero")
puts stack.inspect

front = stack.shift
puts "Removed from front: #{front}"
puts stack.inspect

stack << "appended"
puts stack.inspect

# Querying
animals = ["cat", "dog", "elephant", "fox", "dog", "bear"]
puts animals.include?("dog")
puts animals.include?("lion")
puts animals.index("dog")
puts animals.rindex("dog")
puts animals.count("dog")
puts animals.empty?
puts [].empty?
puts animals.any? { |a| a.length > 5 }
puts animals.all? { |a| a.length > 2 }
puts animals.none? { |a| a.length > 10 }
puts animals.min
puts animals.max
puts animals.minmax.inspect

# Sorting
nums  = [5, 2, 9, 1, 7, 3, 8, 4, 6]
words = ["banana", "apple", "cherry", "date"]
puts nums.sort.inspect
puts words.sort.inspect
puts nums.sort.reverse.inspect
puts nums.sort_by { |n| -n }.inspect
puts words.sort_by { |w| w.length }.inspect
puts nums.sample.class
puts nums.sample(3).inspect
puts [1, 2, 2, 3, 3, 3, 4].uniq.inspect
puts [1, 2, nil, 3, nil, 4].compact.inspect
puts [1, [2, 3], [4, [5, 6]]].flatten.inspect
puts [1, [2, 3], [4, [5, 6]]].flatten(1).inspect

