# Chapter 1 – Getting Started with Ruby
# Example: Hello, World! and basic output

puts "Hello, World!"
puts "This is my first Ruby program."
puts "Ruby is a beautiful language."

# Chapter 1 – puts vs print vs p

puts "Hello from puts"
print "Hello from print"
print " and still on the same line"
puts ""
p "Hello from p"
p 42
p nil

# Chapter 1 – Arithmetic in IRB
# Run these lines one at a time in IRB, or run this file with: ruby 03_irb_arithmetic.rb

puts 2 + 3
puts 10 - 4
puts 6 * 7
puts 20 / 4
puts 2 ** 8

puts "Hello, " + "World!"
puts "Ruby" + " " + "is" + " " + "wonderful"

# Chapter 1 – Sequential execution

puts "Step 1: Ruby reads and runs this line first."
puts "Step 2: Then it moves down to this line."
puts "Step 3: Then this one comes next."
puts "Step 4: Ruby finishes here at the last line."

