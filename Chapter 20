# Chapter 20 – CLI: command-line interface layer

require_relative 'task'
require_relative 'task_repository'

class CLI
  COMMANDS = %w[add list show complete delete stats help].freeze

  def initialize(repo = TaskRepository.new)
    @repo = repo
  end

  def run(args)
    command = args.shift&.downcase
    if command.nil? || command == "help"
      show_help
    elsif COMMANDS.include?(command)
      send("cmd_#{command}", args)
    else
      error "Unknown command: #{command}. Run 'rubytask help' for usage."
    end
  rescue ArgumentError => e
    error e.message
  end

  private

  def cmd_add(args)
    title       = args.shift
    error "Usage: add TITLE [--desc DESCRIPTION] [--priority low|normal|high|urgent]" if title.nil?
    description = extract_option(args, "--desc",     "")
    priority    = extract_option(args, "--priority", "normal")
    task        = Task.new(title: title, description: description, priority: priority)
    saved       = @repo.add(task)
    success "Task ##{saved.id} created: #{saved.title}"
  end

  def cmd_list(args)
    status   = extract_option(args, "--status",   nil)
    priority = extract_option(args, "--priority", nil)
    tasks    = @repo.where(status: status, priority: priority)
    if tasks.empty?
      info "No tasks found."
      return
    end
    tasks.sort_by { |t| [-t.priority_value, t.id] }.each { |t| puts t }
    info "\n#{tasks.length} task(s) shown."
  end

  def cmd_show(args)
    id   = args.first
    error "Usage: show TASK_ID" if id.nil?
    task = @repo.find(id)
    error "Task ##{id} not found." if task.nil?
    puts "=" * 50
    puts "ID:          #{task.id}"
    puts "Title:       #{task.title}"
    puts "Description: #{task.description.empty? ? '(none)' : task.description}"
    puts "Priority:    #{task.priority.upcase}"
    puts "Status:      #{task.status.upcase}"
    puts "Created:     #{task.created_at.strftime('%Y-%m-%d %H:%M')}"
    puts "Completed:   #{task.completed_at ? task.completed_at.strftime('%Y-%m-%d %H:%M') : 'N/A'}"
    puts "=" * 50
  end

  def cmd_complete(args)
    id   = args.first
    error "Usage: complete TASK_ID" if id.nil?
    task = @repo.find(id)
    error "Task ##{id} not found."          if task.nil?
    error "Task ##{id} is already completed." if task.completed?
    @repo.update(task.complete!)
    success "Task ##{task.id} marked as complete."
  end

  def cmd_delete(args)
    id   = args.first
    error "Usage: delete TASK_ID" if id.nil?
    task = @repo.delete(id)
    success "Task ##{task.id} deleted: #{task.title}"
  end

  def cmd_stats(args)
    s = @repo.stats
    puts "=" * 30
    puts "RubyTask Statistics"
    puts "=" * 30
    puts "Total tasks:     #{s[:total]}"
    puts "Completed:       #{s[:completed]}"
    puts "Pending:         #{s[:pending]}"
    puts "Pending by priority:"
    s[:by_priority].each { |pri, count| puts "  #{pri.ljust(8)}: #{count}" }
    rate = s[:total].zero? ? 0 : (s[:completed].to_f / s[:total] * 100).round(1)
    puts "Completion rate: #{rate}%"
    puts "=" * 30
  end

  def show_help
    puts <<~HELP
      RubyTask - Command-line task manager

      Usage: rubytask COMMAND [options]

      Commands:
        add TITLE [--desc TEXT] [--priority low|normal|high|urgent]
        list [--status pending|completed] [--priority low|normal|high|urgent]
        show TASK_ID
        complete TASK_ID
        delete TASK_ID
        stats
        help
    HELP
  end

  def extract_option(args, flag, default)
    idx = args.index(flag)
    return default if idx.nil?
    args.delete_at(idx)
    args.delete_at(idx)
  end

  def error(message)
    warn "Error: #{message}"
    exit(1)
  end

  def success(message)
    puts "OK: #{message}"
  end

  def info(message)
    puts message
  end
end

