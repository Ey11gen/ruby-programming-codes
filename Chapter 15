# Chapter 15 – Pure methods and avoiding side effects

def add(a, b)
  a + b
end

def full_name(first, last)
  "#{first.strip} #{last.strip}".squeeze(" ")
end

def celsius_to_fahrenheit(c)
  (c * 9.0 / 5.0) + 32
end

def classify_temperature(celsius)
  case celsius
  when -Float::INFINITY...0 then "freezing"
  when 0...15              then "cold"
  when 15...25             then "comfortable"
  when 25...35             then "warm"
  else                          "hot"
  end
end

puts add(3, 4)
puts add(3, 4)
puts full_name("  Marie  ", "Curie ")
puts celsius_to_fahrenheit(100)
puts classify_temperature(22)

