# Chapter 13 – open-uri and Net::HTTP

require 'open-uri'
require 'json'
require 'net/http'

# --- Simple GET with open-uri ---
url = "https://jsonplaceholder.typicode.com/posts/1"

begin
  raw  = URI.open(url).read
  data = JSON.parse(raw)
  puts "Title:  #{data['title']}"
  puts "Body:   #{data['body'][0..60]}..."
  puts "UserID: #{data['userId']}"
rescue OpenURI::HTTPError => e
  puts "HTTP Error: #{e.message}"
rescue SocketError => e
  puts "Network unreachable: #{e.message}"
end

# --- POST with Net::HTTP ---
uri = URI.parse("https://jsonplaceholder.typicode.com/posts")

post_body = {
  title:  "My New Post",
  body:   "This is the content of my post.",
  userId: 1
}.to_json

begin
  http          = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl  = true
  request       = Net::HTTP::Post.new(uri.path, "Content-Type" => "application/json")
  request.body  = post_body
  response      = http.request(request)
  puts "Response status: #{response.code} #{response.message}"
  data = JSON.parse(response.body)
  puts "Created post with ID: #{data['id']}"
rescue => e
  puts "Request failed: #{e.class} - #{e.message}"
end
