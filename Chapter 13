require 'date'

today = Date.today
puts today
puts today.year
puts today.month
puts today.day
puts today.monday?
puts today.strftime("%A, %d %B %Y")

birth  = Date.new(1990, 6, 15)
age    = (today - birth).to_i / 365
puts "Age: approximately #{age} years"

future = today + 30
puts "30 days from today: #{future}"

parsed = Date.parse("2025-12-25")
puts "Christmas 2025: #{parsed.strftime('%A, %B %d')}"
puts "Days until then: #{(parsed - today).to_i}"

last_day = Date.new(today.year, today.month, -1)
puts "Last day of this month: #{last_day}"

