# Chapter 13 – Benchmark module

require 'benchmark'

n = 100_000

Benchmark.bm(20) do |x|
  x.report("string concat:") do
    result = ""
    n.times { |i| result = result + i.to_s }
  end

  x.report("string shovel:") do
    result = ""
    n.times { |i| result << i.to_s }
  end

  x.report("array + join:") do
    parts = []
    n.times { |i| parts << i.to_s }
    result = parts.join
  end
end

