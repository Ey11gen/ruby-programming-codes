# Chapter 17 – Calculator class (subject under test)

class Calculator
  def add(a, b)
    raise ArgumentError, "Inputs must be numeric." unless a.is_a?(Numeric) && b.is_a?(Numeric)
    a + b
  end

  def subtract(a, b)
    raise ArgumentError, "Inputs must be numeric." unless a.is_a?(Numeric) && b.is_a?(Numeric)
    a - b
  end

  def multiply(a, b)
    raise ArgumentError, "Inputs must be numeric." unless a.is_a?(Numeric) && b.is_a?(Numeric)
    a * b
  end

  def divide(a, b)
    raise ArgumentError, "Inputs must be numeric." unless a.is_a?(Numeric) && b.is_a?(Numeric)
    raise ZeroDivisionError, "Cannot divide by zero."  if b.zero?
    a.to_f / b
  end
end

# Chapter 17 – RSpec specification for Calculator
# Run with: rspec calculator_spec.rb   (requires: gem install rspec)

require_relative 'calculator'

RSpec.describe Calculator do
  subject(:calc) { Calculator.new }

  describe '#add' do
    context 'with two positive integers' do
      it 'returns their sum' do
        expect(calc.add(3, 4)).to eq(7)
      end

      it 'handles zero correctly' do
        expect(calc.add(0, 0)).to eq(0)
        expect(calc.add(5, 0)).to eq(5)
      end
    end

    context 'with negative numbers' do
      it 'returns the correct negative sum' do
        expect(calc.add(-1, -2)).to eq(-3)
      end

      it 'handles mixed positive and negative numbers' do
        expect(calc.add(-3, 5)).to eq(2)
      end
    end

    context 'with invalid input' do
      it 'raises ArgumentError for non-numeric input' do
        expect { calc.add("3", 4) }.to raise_error(ArgumentError)
        expect { calc.add(nil, 4) }.to raise_error(ArgumentError)
      end
    end
  end

  describe '#divide' do
    it 'returns a float result' do
      expect(calc.divide(5, 2)).to eq(2.5)
    end

    it 'returns an accurate decimal for non-even divisions' do
      expect(calc.divide(10, 3)).to be_within(0.001).of(3.333)
    end

    it 'raises ZeroDivisionError when dividing by zero' do
      expect { calc.divide(10, 0) }.to raise_error(ZeroDivisionError)
    end

    it 'raises ZeroDivisionError with a meaningful message' do
      expect { calc.divide(10, 0) }
        .to raise_error(ZeroDivisionError, /Cannot divide by zero/)
    end
  end
end

# Chapter 17 – Minitest test suite for Calculator
# Run with: ruby test_calculator.rb

require 'minitest/autorun'
require_relative 'calculator'

class TestCalculator < Minitest::Test
  def setup
    @calc = Calculator.new
  end

  def test_add_two_positive_integers
    assert_equal 7,   @calc.add(3, 4)
    assert_equal 0,   @calc.add(0, 0)
    assert_equal 100, @calc.add(99, 1)
  end

  def test_add_negative_numbers
    assert_equal(-3, @calc.add(-1, -2))
    assert_equal  2, @calc.add(-3, 5)
  end

  def test_subtract_returns_correct_result
    assert_equal 5, @calc.subtract(10, 5)
    assert_equal(-3, @calc.subtract(2, 5))
  end

  def test_multiply_integers
    assert_equal 12, @calc.multiply(3, 4)
    assert_equal  0, @calc.multiply(5, 0)
    assert_equal(-6, @calc.multiply(-2, 3))
  end

  def test_divide_returns_float
    assert_equal 2.5, @calc.divide(5, 2)
    assert_equal 0.0, @calc.divide(0, 5)
    assert_in_delta 3.333, @calc.divide(10, 3), 0.001
  end

  def test_divide_by_zero_raises_error
    assert_raises(ZeroDivisionError) { @calc.divide(10, 0) }
    assert_raises(ZeroDivisionError) { @calc.divide(0, 0) }
  end

  def test_add_with_string_raises_argument_error
    assert_raises(ArgumentError) { @calc.add("3", 4) }
    assert_raises(ArgumentError) { @calc.add(3, nil) }
  end
end

# Chapter 17 – Test doubles and dependency injection with Minitest::Mock

require 'minitest/autorun'

class EmailNotifier
  def send_welcome(user_email)
    puts "Sending welcome email to #{user_email}..."
    true
  end
end

class UserRegistration
  def initialize(notifier)
    @notifier = notifier
  end

  def register(email, password)
    raise ArgumentError, "Email cannot be blank." if email.to_s.strip.empty?
    raise ArgumentError, "Password too short."    if password.to_s.length < 8
    @notifier.send_welcome(email)
    { success: true, email: email }
  end
end

class TestUserRegistration < Minitest::Test
  def setup
    @mock_notifier = Minitest::Mock.new
    @registration  = UserRegistration.new(@mock_notifier)
  end

  def test_register_calls_notifier_with_email
    @mock_notifier.expect(:send_welcome, true, ["user@example.com"])
    result = @registration.register("user@example.com", "securepassword")
    assert_equal true, result[:success]
    assert_equal "user@example.com", result[:email]
    @mock_notifier.verify
  end

  def test_register_raises_for_blank_email
    assert_raises(ArgumentError) { @registration.register("", "securepassword") }
  end

  def test_register_raises_for_short_password
    assert_raises(ArgumentError) { @registration.register("user@test.com", "short") }
  end
end
