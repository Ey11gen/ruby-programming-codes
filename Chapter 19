#!/usr/bin/env ruby
# Chapter 19 – Command-line tool with OptionParser
# Usage: ruby 01_option_parser_tool.rb --help
#        ruby 01_option_parser_tool.rb -f csv -v myfile.txt

require 'optparse'
require 'date'

options = {
  format:    "text",
  output:    nil,
  verbose:   false,
  max_lines: 100
}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: report_tool.rb [options] INPUT_FILE"
  opts.separator ""
  opts.separator "Options:"

  opts.on("-f", "--format FORMAT", ["text", "csv", "json"],
          "Output format: text, csv, or json (default: text)") do |fmt|
    options[:format] = fmt
  end

  opts.on("-o", "--output FILE",
          "Write output to FILE instead of stdout") do |file|
    options[:output] = file
  end

  opts.on("-n", "--max-lines N", Integer,
          "Maximum lines to process (default: 100)") do |n|
    options[:max_lines] = n
  end

  opts.on("-v", "--verbose", "Show detailed processing information") do
    options[:verbose] = true
  end

  opts.on("-h", "--help", "Show this help message") do
    puts opts
    exit
  end
end

begin
  parser.parse!(ARGV)
rescue OptionParser::InvalidOption => e
  puts "Error: #{e.message}"
  puts parser
  exit(1)
end

if ARGV.empty?
  puts "Error: INPUT_FILE is required."
  puts parser
  exit(1)
end

input_file = ARGV[0]

puts "Processing: #{input_file}"                         if options[:verbose]
puts "Format:     #{options[:format]}"                   if options[:verbose]
puts "Max lines:  #{options[:max_lines]}"                if options[:verbose]
puts "Output to:  #{options[:output] || 'stdout'}"       if options[:verbose]
puts "Report generation complete for: #{input_file}"

#!/usr/bin/env ruby
# Chapter 19 – File organizer: sorts files into subdirectories by extension
# Usage: ruby 02_file_organizer.rb [directory] [--dry-run]

require 'fileutils'

EXTENSION_CATEGORIES = {
  "images"    => %w[.jpg .jpeg .png .gif .bmp .webp .svg .ico],
  "documents" => %w[.pdf .doc .docx .txt .md .rtf .odt .xlsx .csv],
  "videos"    => %w[.mp4 .mkv .avi .mov .wmv .flv .webm],
  "audio"     => %w[.mp3 .wav .flac .aac .ogg .wma .m4a],
  "archives"  => %w[.zip .tar .gz .rar .7z .bz2],
  "code"      => %w[.rb .py .js .ts .html .css .java .go .rs .sh],
}.freeze

def find_category(extension)
  EXTENSION_CATEGORIES.each do |category, extensions|
    return category if extensions.include?(extension.downcase)
  end
  "other"
end

def organize_directory(source_dir, dry_run: false)
  moved   = 0
  skipped = 0
  errors  = 0

  Dir.glob(File.join(source_dir, "*")).each do |filepath|
    next unless File.file?(filepath)

    filename  = File.basename(filepath)
    extension = File.extname(filepath)
    category  = find_category(extension)

    dest_dir  = File.join(source_dir, category)
    dest_path = File.join(dest_dir, filename)

    if File.exist?(dest_path) && filepath != dest_path
      puts "  SKIP (exists): #{filename}"
      skipped += 1
      next
    end

    puts "  #{dry_run ? 'WOULD MOVE' : 'MOVING'}: #{filename} -> #{category}/"

    unless dry_run
      begin
        FileUtils.mkdir_p(dest_dir)
        FileUtils.mv(filepath, dest_path)
        moved += 1
      rescue => e
        puts "  ERROR: #{e.message}"
        errors += 1
      end
    end
  end

  puts "\nSummary: #{moved} moved, #{skipped} skipped, #{errors} errors."
end

source = ARGV[0] || Dir.pwd
dry    = ARGV.include?("--dry-run")

puts "Organizing files in: #{File.expand_path(source)}"
puts "(DRY RUN - no files will be moved)" if dry
puts
organize_directory(source, dry_run: dry)

# Chapter 19 – Web scraping with Nokogiri
# Install: gem install nokogiri

require 'nokogiri'
require 'open-uri'
require 'json'

# --- Parse a local HTML string ---
def parse_local_html(html_content)
  doc = Nokogiri::HTML(html_content)

  puts "All links on the page:"
  doc.css("a[href]").each do |link|
    href = link["href"]
    text = link.text.strip
    puts "  #{text.empty? ? '(no text)' : text}: #{href}" unless href.start_with?("#")
  end

  puts "\nAll headings:"
  doc.css("h1, h2, h3").each do |heading|
    level = heading.name
    puts "  [#{level}] #{heading.text.strip}"
  end

  puts "\nAll images:"
  doc.css("img[src]").each do |img|
    puts "  src=#{img['src']} alt=#{img['alt'] || '(none)'}"
  end
end

sample_html = <<~HTML
  <html>
    <body>
      <h1>Ruby News</h1>
      <h2>Latest Releases</h2>
      <p>Check out <a href="https://ruby-lang.org">Ruby's website</a> for updates.</p>
      <img src="ruby-logo.png" alt="Ruby Logo">
      <h3>Community Resources</h3>
      <a href="#section1">Jump to section</a>
      <a href="https://rubygems.org">RubyGems.org</a>
      <a href="https://rubyweekly.com">Ruby Weekly</a>
    </body>
  </html>
HTML

parse_local_html(sample_html)

