# Chapter 19 – Running external commands from Ruby

# system: runs command, prints output to terminal, returns true/false
system_result = system("echo Hello from a system call")
puts "Command succeeded: #{system_result}"
puts

# %x(): runs command and captures its output as a string
output = %x(echo "This output is captured")
puts "Captured: #{output.chomp}"
puts

# Check exit status with $?
git_log = %x(git log --oneline -5 2>&1)
if $?.success?
  puts "Recent commits:"
  git_log.each_line { |line| puts "  #{line.chomp}" }
else
  puts "Not a git repository or git not installed."
end
puts

# Open3 for full control over stdin, stdout, stderr separately
require 'open3'

stdout, stderr, status = Open3.capture3("ruby", "--version")
puts "Ruby version output: #{stdout.chomp}"
puts "Exit status: #{status.exitstatus}"
puts

# Open3.popen2e for streaming output as command runs
Open3.popen2e("ls", "-la") do |stdin, stdout_err, thread|
  stdout_err.each_line { |line| puts line }
  puts "Process exit status: #{thread.value.exitstatus}"
end

#!/usr/bin/env ruby
# Chapter 19 – Practical automation: log file monitor
# Demonstrates file watching, pattern matching, and reporting

require 'date'

# Simulate a log file for demonstration
SAMPLE_LOG = <<~LOG
  2024-03-15 08:01:12 INFO  Server started on port 3000
  2024-03-15 08:01:15 INFO  Database connection established
  2024-03-15 08:05:22 WARN  High memory usage: 78%
  2024-03-15 08:07:44 ERROR Cannot connect to cache service
  2024-03-15 08:07:45 ERROR Retry 1/3 for cache connection
  2024-03-15 08:07:47 INFO  Cache connection restored
  2024-03-15 08:12:03 WARN  Slow query detected: 2300ms
  2024-03-15 08:15:55 ERROR Unhandled exception in worker thread
  2024-03-15 08:30:00 INFO  Health check passed
  2024-03-15 08:45:10 WARN  Disk usage at 85%
LOG

def parse_log_entries(log_text)
  entries = []
  log_text.each_line do |line|
    line = line.chomp
    next if line.empty?
    match = line.match(/(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}) (INFO|WARN|ERROR)\s+(.+)/)
    next unless match
    entries << { timestamp: match[1], level: match[2], message: match[3] }
  end
  entries
end

def analyze_log(entries)
  by_level = entries.group_by { |e| e[:level] }

  puts "=" * 55
  puts "Log Analysis Report"
  puts "=" * 55
  puts "Total entries: #{entries.length}"
  puts "INFO:  #{by_level['INFO']&.length  || 0}"
  puts "WARN:  #{by_level['WARN']&.length  || 0}"
  puts "ERROR: #{by_level['ERROR']&.length || 0}"
  puts

  if by_level['ERROR']
    puts "Errors found:"
    by_level['ERROR'].each { |e| puts "  [#{e[:timestamp]}] #{e[:message]}" }
    puts
  end

  if by_level['WARN']
    puts "Warnings:"
    by_level['WARN'].each { |e| puts "  [#{e[:timestamp]}] #{e[:message]}" }
  end
  puts "=" * 55
end

entries = parse_log_entries(SAMPLE_LOG)
analyze_log(entries)
